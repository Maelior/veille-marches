# Copie ce fichier en ".env" et remplis les valeurs.
# Le fichier .env ne doit JAMAIS être commité sur GitHub (voir .gitignore).

# --- Clés API (obligatoires) ---
ANTHROPIC_API_KEY=sk-ant-...
RESEND_API_KEY=re_...

# --- Email ---
# Expéditeur : "Nom <adresse@ton-domaine.fr>" (domaine vérifié chez Resend)
# Pour un premier test, tu peux laisser onboarding@resend.dev
EMAIL_FROM=Veille Maelior <onboarding@resend.dev>
# Destinataire(s), séparés par des virgules
EMAIL_TO=client@exemple.fr
# Envoyer un email même sans annonce ? true / false
SEND_IF_EMPTY=true

# --- Filtres ---
DEPARTEMENTS=59,62
MOTS_CLES=terrassement,VRD,réseaux,réseau,voirie,voiries,fondation,fondations,gros oeuvre,gros œuvre,assainissement,canalisation,canalisations,génie civil,enrobé,enrobés,tranchée,remblai,déblai
# 1 = uniquement la veille. Mets 3 le lundi si tu veux rattraper le week-end.
LOOKBACK_DAYS=1

# --- Modèle Claude (optionnel) ---
ANTHROPIC_MODEL=claude-sonnet-4-20250514
